rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유틸리티 함수: 사용자가 인증되었는지 확인
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Firestore 문서의 role 필드를 조회하여 권한을 확인합니다.
    function getRole() { 
      let path = /databases/$(database)/documents/UserProfile/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'GUEST';
    }
    
    function isAdmin() { return isAuthenticated() && getRole() == 'ADMIN'; }
    function isSubAdmin() { return isAuthenticated() && getRole() == 'SUB_ADMIN'; }
    function isManagement() { return isAdmin() || isSubAdmin(); }

    // 본부 관리 (divisions)
    match /divisions/{divisionId} {
      allow read, write: if isAuthenticated();
    }

    // 팀 관리 (teams)
    match /teams/{teamId} {
      allow read, write: if isAuthenticated();
    }

    // 유저/직원 프로필 관리 (UserProfile)
    match /UserProfile/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.email == request.auth.token.email);
    }

    // 결재 승인 관련 유틸리티 함수
    function isSubAdminOfDivision(divId) {
      let path = /databases/$(database)/documents/UserProfile/$(request.auth.uid);
      return isSubAdmin() && exists(path) && get(path).data.divisionId == divId;
    }

    function isValidApproval(currentStatus, nextStatus, targetDivId) {
      let isFinalSet = nextStatus == 'APPROVED';
      let isSubSet = nextStatus == 'SUB_APPROVED';
      let isReject = nextStatus == 'REJECTED';
      let isUndo = nextStatus == 'PENDING';

      // 1. 마스터 관리자(ADMIN)는 모든 것이 가능 (상태에 상관없이 최종 승인/반려/되돌리기)
      if (isAdmin()) { return true; }

      // 2. 부관리자(SUB_ADMIN) 제약
      if (isSubAdminOfDivision(targetDivId)) {
        // 부관리자는 'PENDING' 상태에서만 'SUB_APPROVED' 또는 'REJECTED'로 변경 가능
        return currentStatus == 'PENDING' && (isSubSet || isReject);
      }

      return false;
    }

    // 경비 신청 (expenses)
    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING') || 
        isValidApproval(resource.data.status, request.resource.data.status, resource.data.divisionId)
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING' || isAdmin());
    }

    // 휴가 신청 (leaves)
    match /leaves/{leaveId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING') || 
        isValidApproval(resource.data.status, request.resource.data.status, resource.data.divisionId)
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING' || isAdmin());
    }

    // 근태 기록 (attendance)
    match /attendance/{atId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagement());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 기본 규칙: 그 외 모든 컬렉션은 가급적 어드민만 접근 가능하게 방어
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
