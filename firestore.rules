rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() { return request.auth != null; }
    
    // Firestore 문서의 role 필드를 조회하여 권한을 확인합니다.
    function getRole() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; 
    }
    
    function isAdmin() { return isAuthenticated() && getRole() == 'ADMIN'; }
    function isSubAdmin() { return isAuthenticated() && getRole() == 'SUB_ADMIN'; }
    function isManagement() { return isAdmin() || isSubAdmin(); }

    // 컬렉션 규칙 (소문자로 통일)
    
    // 본부 관리 (divisions)
    match /divisions/{divisionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // 본부 생성/삭제는 최고 관리자만
    }

    // 팀 관리 (teams)
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isManagement(); // 팀 생성/수정은 (최고/부) 관리자 가능
    }

    // 유저 관리 (users)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isManagement() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // 근태 기록 (attendance)
    match /attendance/{recordId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (request.auth.uid == request.resource.data.userId || isManagement());
      allow delete: if isManagement();
    }

    // 휴가 신청 (leave_requests)
    match /leave_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isManagement());
      allow delete: if isManagement();
    }

    // 지출 결의 (expense_requests)
    match /expense_requests/{expenseId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isManagement());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isManagement());
      allow delete: if isAdmin();
    }

    // 알람 및 공지 (notifications)
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create, delete: if isManagement();
      allow update: if isAuthenticated() && (
        isManagement() || 
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
          request.resource.data.readBy.hasAll([request.auth.uid])
        )
      );
    }
  }
}
