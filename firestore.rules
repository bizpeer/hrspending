rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유틸리티 함수: 사용자가 인증되었는지 확인
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Firestore 문서의 role 필드를 조회하여 권한을 확인합니다.
    function getRole() { 
      let path = /databases/$(database)/documents/UserProfile/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'GUEST';
    }
    
    function isAdmin() { return isAuthenticated() && getRole() == 'ADMIN'; }
    function isSubAdmin() { return isAuthenticated() && getRole() == 'SUB_ADMIN'; }
    function isManagement() { return isAdmin() || isSubAdmin(); }

    // 본부 관리 (divisions)
    match /divisions/{divisionId} {
      allow read, write: if isAuthenticated();
    }

    // 팀 관리 (teams)
    match /teams/{teamId} {
      allow read, write: if isAuthenticated();
    }

    // 유저/직원 프로필 관리 (UserProfile)
    match /UserProfile/{userId} {
      // 본인의 프로필은 읽고 쓸 수 있으며, 관리자는 모든 프로필 관리 가능
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // 마이그레이션을 위해 자신의 이메일이 등록된 임시 프로필 삭제 허용
      allow delete: if isAuthenticated() && (resource.data.email == request.auth.token.email);
      
      // 로그인 시 이메일로 본인의 임시 프로필을 찾기 위해 리스트 조회 허용
      allow list: if isAuthenticated();
    }

    // 감사 로그 (AuditLogs)
    match /AuditLogs/{logId} {
      allow read, write: if true;
    }

    // 공지사항 (announcements)
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isManagement();
    }

    // 경비 신청 (expenses)
    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagement());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 휴가 신청 (leaves)
    match /leaves/{leaveId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagement());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 기본 규칙: 그 외 모든 컬렉션은 가급적 어드민만 접근 가능하게 방어
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
