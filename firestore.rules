rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() { return request.auth != null; }
    function isDirector() { return isAuthenticated() && request.auth.token.role == 'DIRECTOR'; }
    function isHRAdmin() { return isAuthenticated() && request.auth.token.role == 'HR_ADMIN'; }
    function isHRAdminOrDirector() { return isHRAdmin() || isDirector(); }
    function isFinance() { return isAuthenticated() && request.auth.token.role == 'FINANCE'; }
    function isFinanceDirector() { return isAuthenticated() && request.auth.token.role == 'FINANCE_DIRECTOR'; }

    // 기존 컬렉션들 (Divisions, Teams, UserProfile, Attendance, LeaveRequests, ExpenseRequests)
    match /Divisions/{divisionId} { allow read: if isAuthenticated(); allow write: if isHRAdminOrDirector(); }
    match /Teams/{teamId} { allow read: if isAuthenticated(); allow write: if isHRAdminOrDirector(); }
    match /UserProfile/{userId} {
      allow read: if isAuthenticated();
      allow write: if isHRAdminOrDirector() || request.auth.uid == userId;
    }
    match /Attendance/{recordId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (request.auth.uid == request.resource.data.userId || isHRAdminOrDirector());
      allow delete: if isHRAdminOrDirector();
    }
    match /LeaveRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated(); 
      allow delete: if isHRAdminOrDirector();
    }
    match /ExpenseRequests/{expenseId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isFinance() || isFinanceDirector() || isDirector());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isFinance() || isFinanceDirector() || isDirector());
      allow delete: if isDirector();
    }

    // NEW: 알람 및 사내 공지 (Notifications)
    match /Notifications/{notificationId} {
      // 모든 직원이 전체 알람 및 공지 조회 허용
      allow read: if isAuthenticated();

      // 생성 ও 삭제는 대표이사 또는 인사담당자 가능
      allow create, delete: if isHRAdminOrDirector();

      // 업데이트(수정) 권한 구분:
      // 1. 관리자는 전체 내용을 수정할 수 있음.
      // 2. 일반 직원은 오직 `readBy` 배열에 본인의 uid 요소를 추가(arrayUnion)하는 읽음 처리 업데이트만 가능하도록 허가.
      allow update: if isAuthenticated() && (
        isHRAdminOrDirector() || 
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
          request.resource.data.readBy.hasAll([request.auth.uid])
        )
      );
    }
  }
}
